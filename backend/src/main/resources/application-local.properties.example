spring.application.name=EtsyBackend

# Server
server.port=8081

# Database
spring.datasource.url=jdbc:postgresql://localhost:5433/etsy_extension
spring.datasource.username=postgres
spring.datasource.password=postgres
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=true
spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.PostgreSQLDialect

# Google OAuth2 — Chrome Extension client ID
google.oauth2.client-id=your-chrome-extension-client-id

# JWT (min 32 characters)
jwt.secret=change-me-to-a-long-random-secret-at-least-32-chars
jwt.expiration=86400000

# Paddle — Paddle dashboard'dan gerçek değerleri yaz
paddle.api-key=your_paddle_api_key
paddle.environment=sandbox
paddle.webhook-secret=your_webhook_secret
paddle.price-id-monthly=pri_your_monthly_price_id
paddle.price-id-yearly=pri_your_yearly_price_id
paddle.success-url=http://localhost:8081/checkout/success?success=1
paddle.cancel-url=http://localhost:8081/checkout/cancel

# CORS — SecurityConfig içinde chrome-extension://* tanımlı

# Swagger
springdoc.api-docs.path=/api-docs
swagger.username=admin
swagger.password=change-me-swagger-password
