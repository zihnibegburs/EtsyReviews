# Environment Variables Template
# Copy this file to .env and fill in your actual values

# Google OAuth2 — Chrome Extension client ID (extension/manifest.json oauth2.client_id ile aynı)
GOOGLE_CLIENT_ID=your-chrome-extension-client-id

# Lemon Squeezy Payment
LEMONSQUEEZY_API_KEY=your_api_key
LEMONSQUEEZY_STORE_ID=your_store_id
LEMONSQUEEZY_WEBHOOK_SECRET=your_webhook_secret
LEMONSQUEEZY_VARIANT_ID_MONTHLY=your_monthly_variant_id
LEMONSQUEEZY_VARIANT_ID_YEARLY=your_yearly_variant_id

# Admin — manual subscription grants (POST /api/admin/subscription/grant)
ADMIN_API_KEY=your_long_random_admin_secret

# Swagger UI basic auth (/swagger-ui/index.html)
SWAGGER_USERNAME=admin
SWAGGER_PASSWORD=your_long_random_swagger_password

# Database (for Docker Compose)
POSTGRES_PASSWORD=postgres
