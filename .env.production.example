# Production (Time4VPS) — kopyala: cp .env.production.example .env

# Public API domain (DNS A kaydı bu sunucunun IP'sine işaret etmeli)
API_DOMAIN=api.etsyfetcher.shop

# PostgreSQL
POSTGRES_USER=etsy
POSTGRES_PASSWORD=change-me-long-random-password

# JWT (en az 32 karakter)
JWT_SECRET=change-me-super-secret-jwt-key-min-32-chars

# Google OAuth — extension/manifest.json oauth2.client_id ile aynı
GOOGLE_CLIENT_ID=your-chrome-extension-client-id

# Lemon Squeezy
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=
LEMONSQUEEZY_VARIANT_ID_MONTHLY=
LEMONSQUEEZY_VARIANT_ID_YEARLY=
LEMONSQUEEZY_SUCCESS_URL=https://api.etsyfetcher.shop/checkout/success?success=1
LEMONSQUEEZY_CANCEL_URL=https://api.etsyfetcher.shop/checkout/cancel

# Admin — POST /api/admin/subscription/grant
ADMIN_API_KEY=

# Swagger UI basic auth
SWAGGER_USERNAME=admin
SWAGGER_PASSWORD=change-me-long-random-swagger-password

# JVM — 2 GB VPS için önerilen (tırnak zorunlu)
JAVA_OPTS="-Xmx512m -Xms256m"

# 1 GB VPS kullanıyorsan şunu kullan:
# JAVA_OPTS="-Xmx384m -Xms128m -XX:+UseSerialGC"
