# Copy to .env at repo root for docker-compose

# Google OAuth2
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Stripe
STRIPE_SECRET_KEY=sk_test_your_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRICE_ID_MONTHLY=price_your_monthly_id
STRIPE_PRICE_ID_YEARLY=price_your_yearly_id

# CORS (include your Chrome extension origin)
CORS_ALLOWED_ORIGINS=chrome-extension://your-extension-id,http://localhost:3000
