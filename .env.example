# Copy to .env at repo root for docker-compose

# Google OAuth2 — Chrome Extension client ID
GOOGLE_CLIENT_ID=your-chrome-extension-client-id

# Paddle
PADDLE_API_KEY=your_api_key
PADDLE_ENVIRONMENT=sandbox
PADDLE_WEBHOOK_SECRET=your_webhook_secret
PADDLE_PRICE_ID_MONTHLY=pri_your_monthly_price_id
PADDLE_PRICE_ID_YEARLY=pri_your_yearly_price_id

# CORS (include your Chrome extension origin)
CORS_ALLOWED_ORIGINS=chrome-extension://your-extension-id,http://localhost:3000
