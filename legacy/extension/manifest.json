{
  "manifest_version": 3,
  "name": "Etsy Review Scraper",
  "version": "1.0",
  "description": "Scrapes Etsy listing data (csrfToken, listingId, shopId) and makes it available in the popup.",
  "key":"",
  "permissions": [
    "scripting",
    "tabs",
    "storage"
  ],

  "host_permissions": [
    "https://www.etsy.com/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html"
  },

  "content_scripts": [
    {
      "matches": ["https://www.etsy.com/listing/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "web_accessible_resources": [
    {
      "resources": ["output.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
