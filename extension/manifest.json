{
  "manifest_version": 3,
  "name": "Etsy Extension",
  "version": "1.0.0",
  "description": "Chrome extension for Etsy with subscription management",
  "key": "",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "identity",
    "tabs",
    "alarms",
    "scripting"
  ],
  "host_permissions": [
    "http://localhost:8081/*",
    "https://api.etsyfetcher.shop/*",
    "https://www.googleapis.com/*",
    "https://*.paddle.com/*",
    "*://www.etsy.com/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://www.etsy.com/listing/*", "*://etsy.com/listing/*"],
      "js": ["content/content.js"],
      "css": ["content/content.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["output.html", "output.js", "checkout.html", "checkout.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "oauth2": {
    "client_id": "392877515606-8nbfqlat4elu1t1g7mof1gfo4dhmao5i.apps.googleusercontent.com",
    "scopes": [
      "openid",
      "https://www.googleapis.com/auth/userinfo.email",
      "https://www.googleapis.com/auth/userinfo.profile"
    ]
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  }
}

