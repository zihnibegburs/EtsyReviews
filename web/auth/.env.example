# Google OAuth (web app)
GOOGLE_CLIENT_ID_WEB=your-google-client-id
GOOGLE_CLIENT_SECRET_WEB=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# Session
SESSION_COOKIE_NAME=etsy_session
SESSION_SECRET=change-me-to-a-long-random-string

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5435/oauth
